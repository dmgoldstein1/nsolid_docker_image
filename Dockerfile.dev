# Development Dockerfile for the N|Solid runtime service.
# Generated by GitHub Copilot using GPT-5.4.
# Installs runtime dependencies once so source changes can be bind-mounted.

FROM nodesource/nsolid:latest

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev || npm install --omit=dev

ENV NSOLID_COMMAND=nsolid-console:9001
ENV NSOLID_DATA_PATH=/data/nsolid
ENV NODE_ENV=development
ENV PORT=3000

RUN mkdir -p /data/nsolid

EXPOSE 3000

CMD ["node", "--watch", "server.js"]